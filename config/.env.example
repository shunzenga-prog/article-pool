# Article Pool 配置文件模板
# 请复制此文件到 ~/.openclaw/workspace/scripts/.env 并填入你的 API Keys

# ===================================
# Brave Search API（用于网络搜索）
# ===================================
# 获取方式：https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# ===================================
# 微信公众号 API（用于发布文章）
# ===================================
# 获取方式：登录 mp.weixin.qq.com → 设置与开发 → 基本配置
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ===================================
# 其他可选配置
# ===================================
# 默认封面图路径（可选）
DEFAULT_COVER_IMAGE=/path/to/your/default-cover.jpg

# 输出目录（可选）
OUTPUT_DIR=~/.openclaw/workspace/reports

# ===================================
# 注意事项
# ===================================
# 1. 不要将此文件提交到 Git
# 2. Brave Search API 有免费额度限制（2000 次/月）
# 3. 微信公众号 API 需要 IP 白名单配置