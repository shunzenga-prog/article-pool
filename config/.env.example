# Article Pool 配置文件模板
# 请复制此文件到 config/.env 并填入你的 API Keys

# ===================================
# Pexels 图库 API（推荐，免费）
# ===================================
# 获取方式：https://www.pexels.com/api/
# 1. 注册 Pexels 账号
# 2. 访问 https://www.pexels.com/api/new/ 创建应用
# 3. 复制 API Key 填入下方
# 免费额度：200 次/小时，20,000 次/月
# 用途：为封面图搜索高质量摄影照片作为背景
PEXELS_API_KEY=your_pexels_api_key_here

# ===================================
# Brave Search API（用于网络搜索和图片搜索）
# ===================================
# 获取方式：https://brave.com/search/api/
# 免费额度：2,000 次/月
BRAVE_API_KEY=your_brave_api_key_here

# ===================================
# 微信公众号 API（用于发布文章）
# ===================================
# 获取方式：登录 mp.weixin.qq.com → 设置与开发 → 基本配置
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ===================================
# 封面图配图优先级（自动模式）
# ===================================
# T1: 文章内链接的 OG:Image（自动提取）
# T2: Pexels 图库搜索（需要 PEXELS_API_KEY）
# T3: AI 生成图片 Pollinations.ai（免费，无需 API Key）
# T4: Unsplash 搜索（免费，无需 API Key）
# T5: Brave 图片搜索（需要 BRAVE_API_KEY）
# T6: 几何抽象设计（始终可用）

# ===================================
# 工作目录配置（可选，不配则使用项目内默认路径）
# ===================================
# WORK_DIR — 一键配置所有临时/输出文件的总目录
#   设置后，插图、报告、输出会自动归类到 WORK_DIR 的子目录：
#     $WORK_DIR/illustrations/  $WORK_DIR/reports/  $WORK_DIR/output/
#   未设置时，所有文件落在项目目录内（向后兼容）。
# WORK_DIR=E:/WorkSpace/创作/temp

# 独立覆盖（优先级高于 WORK_DIR）
# ILLUSTRATIONS_DIR=test_images/illustrations
# REPORTS_DIR=reports
# OUTPUT_DIR=output
# SCRAPE_OUTPUT_DIR=~/.openclaw/workspace/reports/materials

# ===================================
# 其他可选配置
# ===================================
# 默认封面图路径（可选）
DEFAULT_COVER_IMAGE=/path/to/your/default-cover.jpg

# ===================================
# 注意事项
# ===================================
# 1. 不要将此文件提交到 Git
# 2. 推荐至少配置 PEXELS_API_KEY（免费、图片质量最高）
# 3. 微信公众号 API 需要 IP 白名单配置
