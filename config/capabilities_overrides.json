{
  "overrides": {
    "review_agent": {
      "is_quality_gate": true,
      "blocking": true,
      "retry_on_fail": 0,
      "on_fail": "back_to_writer",
      "description": "扫描 HTML 结构、微信 CSS 兼容性、视觉质量，硬检查失败 = 驳回"
    },
    "cover_agent": {
      "is_quality_gate": false,
      "blocking": false,
      "on_fail": "retry",
      "retry_on_fail": 2,
      "constraints": ["force_auto_mode", "verify_size_gt_100kb"]
    },
    "publish_agent": {
      "is_terminal_stage": true,
      "cannot_skip": true,
      "blocking": true,
      "retry_on_fail": 2,
      "on_fail": "retry_then_escalate"
    },
    "illustration_agent": {
      "is_quality_gate": false,
      "blocking": false,
      "on_fail": "skip_and_continue",
      "retry_on_fail": 1
    },
    "wechat_writer": {
      "description": "公众号爆款文章创作 — 标题/开头/正文/结尾 + SCQA 框架 + 反 AI 模式"
    },
    "article_pipeline": {
      "description": "多 Agent 协作创作链 — 分流→创作→审阅→插图→封面→发布"
    },
    "cover_gen": {
      "deprecated": true, "replaced_by": "cover_agent",
      "description": "[已废弃] 封面生成 Skill 版，请使用 cover_agent"
    },
    "illustration_gen": {
      "deprecated": true, "replaced_by": "illustration_agent",
      "description": "[已废弃] 插图生成 Skill 版，请使用 illustration_agent"
    },
    "script.gen_cover": {
      "deprecated": true, "replaced_by": "cover_agent",
      "description": "[已废弃] 封面 CLI 直接调用，请使用 cover_agent"
    },
    "script.illustration_gen": {
      "deprecated": true, "replaced_by": "illustration_agent",
      "description": "[已废弃] 插图 CLI 直接调用，请使用 illustration_agent"
    },
    "script.publish_html": {
      "constraints": ["windows_require_pythonioencoding_utf8", "must_see_success_output"],
      "is_terminal_stage": true
    },
    "script.tutorial_screenshot": {
      "type": "script",
      "file": "scripts/tutorial_screenshot.py",
      "params": {
        "script": {"type": "str", "required": true},
        "args": {"type": "str", "default": ""},
        "output": {"type": "str", "required": true},
        "verify": {"type": "str", "default": ""},
        "title": {"type": "str", "default": "PowerShell"}
      },
      "constraints": ["tutorial_pipeline_only"],
      "description": "教程截图自动化——跑Python代码→截终端输出→验证结果"
    },
    "script.topic_tracker": {
      "type": "script",
      "file": "scripts/topic_tracker.py",
      "params": {"list": {"type": "flag"}, "add": {"type": "positional"}},
      "constraints": ["post_publish_action"],
      "description": "选题入库，防止重复创作"
    }
  }
}
