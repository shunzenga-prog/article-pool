{
  "$schema": "https://openclaw.ai/schemas/agents-config.json",
  "description": "龙虾军团 Agent 配置模板 - 复制此配置到你的 openclaw.json 中",
  "usage": {
    "steps": [
      "1. 复制 agents.list 数组中的内容",
      "2. 粘贴到 ~/.openclaw/openclaw.json 的 agents.list 中",
      "3. 根据需要修改 workspace 路径",
      "4. 重启 Gateway: openclaw gateway restart"
    ]
  },
  "agents": {
    "list": [
      {
        "id": "code-lobster",
        "name": "代码龙虾",
        "description": "负责脚本编写、代码维护、自动化任务",
        "workspace": "${ARTICLE_POOL_DIR}/agents/lobster-farm/code",
        "agentDir": "${HOME}/.openclaw/agents/code-lobster",
        "model": "bailian/glm-5",
        "skills": ["coding-agent"]
      },
      {
        "id": "design-lobster",
        "name": "设计龙虾",
        "description": "负责封面设计、排版优化、视觉呈现",
        "workspace": "${ARTICLE_POOL_DIR}/agents/lobster-farm/design",
        "agentDir": "${HOME}/.openclaw/agents/design-lobster",
        "model": "bailian/kimi-k2.5",
        "skills": ["image-cog"]
      },
      {
        "id": "research-lobster",
        "name": "研究龙虾",
        "description": "负责热点追踪、新闻搜索、素材整理",
        "workspace": "${ARTICLE_POOL_DIR}/agents/lobster-farm/research",
        "agentDir": "${HOME}/.openclaw/agents/research-lobster",
        "model": "bailian/glm-5",
        "skills": ["hotspot-tracker", "research-lobster", "news-aggregator"]
      },
      {
        "id": "archive-lobster",
        "name": "档案龙虾",
        "description": "负责 memory 整理、文档归档、git 提交",
        "workspace": "${ARTICLE_POOL_DIR}/agents/lobster-farm/archive",
        "agentDir": "${HOME}/.openclaw/agents/archive-lobster",
        "model": "bailian/qwen3.5-plus",
        "skills": []
      },
      {
        "id": "surf-lobster",
        "name": "冲浪龙虾",
        "description": "负责爆款案例收集、素材整理",
        "workspace": "${ARTICLE_POOL_DIR}/agents/lobster-farm/surf",
        "agentDir": "${HOME}/.openclaw/agents/surf-lobster",
        "model": "bailian/kimi-k2.5",
        "skills": []
      },
      {
        "id": "growth-lobster",
        "name": "运营龙虾",
        "description": "负责公众号运营、评论监控、数据分析",
        "workspace": "${ARTICLE_POOL_DIR}/agents/lobster-farm/growth",
        "agentDir": "${HOME}/.openclaw/agents/growth-lobster",
        "model": "bailian/qwen3.5-plus",
        "skills": ["wechat-mp-cn"]
      }
    ]
  },
  "notes": {
    "ARTICLE_POOL_DIR": "替换为你的 article-pool 目录路径，如 /home/user/projects/article-pool",
    "model_options": [
      "bailian/glm-5 - 智谱 GLM-5，性价比高",
      "bailian/qwen3.5-plus - 通义千问，多模态",
      "bailian/kimi-k2.5 - Kimi，长文本强"
    ],
    "customization": "可根据需要调整 model、skills 配置"
  }
}